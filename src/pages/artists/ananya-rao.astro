---
import Layout from "../../layouts/Layout.astro";

const artist = {
  name: "Ananya Rao",
  style: "Carnatic vocals",
  image: "/artist-placeholders/ananya-rao.png",
  alt: "Portrait of Carnatic vocalist Ananya Rao",
  location: "Available for intimate concerts, recordings, and devotional gatherings",
  // Paste real artist links here when available.
  spotifyUrl: "",
  soundCloudUrl:
    "https://soundcloud.com/srikanth-s-iyer/nada-tanumanisham/s-OVaY8op0hNW",
  bookingUrl: "/contact",
  soundCloudEmbedUrl:
    "https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/soundcloud%3Atracks%3A2121207228%3Fsecret_token%3Ds-OVaY8op0hNW&color=%23fcd34d&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true",
  soundCloudUserUrl: "https://soundcloud.com/srikanth-s-iyer",
  soundCloudUserName: "Theorshan Music",
  soundCloudTrackTitle: "Nada Tanumanisham",
  bio:
    "Ananya Rao is presented as a warm Carnatic vocalist for intimate Theorshan experiences: at-home kutcheris, sacred-space concerts, bhajan evenings, and focused studio recordings. Her profile can evolve as real recordings, repertoire, and performance history are added.",
  highlights: [
    "Carnatic vocal concerts for small rooms and at-home gatherings",
    "Devotional repertoire for bhajan evenings and sacred spaces",
    "Studio recording sessions for singles, EPs, and album projects",
  ],
  repertoire: ["Varnams", "Kritis", "Bhajans", "Viruttams", "Devotional albums"],
};
---

<Layout title={`${artist.name} | Theorshan`}>
  <section class="bg-black px-5 py-20 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="overflow-hidden border border-white/15 bg-stone-950">
        <img src={artist.image} alt={artist.alt} class="h-[520px] w-full object-cover" />
      </div>

      <div>
        <p class="text-sm uppercase tracking-[0.35em] text-amber-300">{artist.style}</p>
        <h1 class="mt-5 font-serif text-6xl leading-none text-white sm:text-7xl">{artist.name}</h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-stone-300">{artist.location}</p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a
            href={artist.bookingUrl}
            class="rounded bg-amber-300 px-7 py-4 text-center font-semibold text-black shadow-xl shadow-amber-950/30 transition hover:bg-amber-200"
          >
            Book Ananya
          </a>

          {
            artist.spotifyUrl && (
              <a
                href={artist.spotifyUrl}
                target="_blank"
                rel="noreferrer"
                class="rounded border border-white/35 bg-white/10 px-7 py-4 text-center font-semibold text-white transition hover:border-amber-300 hover:text-amber-200"
              >
                Spotify
              </a>
            )
          }

          {
            artist.soundCloudUrl && (
              <a
                href={artist.soundCloudUrl}
                target="_blank"
                rel="noreferrer"
                class="rounded border border-white/35 bg-white/10 px-7 py-4 text-center font-semibold text-white transition hover:border-amber-300 hover:text-amber-200"
              >
                SoundCloud
              </a>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-stone-950 px-5 py-20 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="text-sm uppercase tracking-[0.35em] text-amber-300">Bio</p>
        <h2 class="mt-4 font-serif text-4xl text-white">A voice for close listening.</h2>
      </div>

      <div>
        <p class="text-lg leading-relaxed text-stone-300">{artist.bio}</p>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {
            artist.highlights.map((highlight) => (
              <div class="border border-white/15 bg-black p-5">
                <p class="leading-relaxed text-stone-300">{highlight}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-black px-5 py-20 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="text-sm uppercase tracking-[0.35em] text-amber-300">Listen</p>
        <h2 class="mt-4 font-serif text-4xl text-white">Streaming links and sample tracks.</h2>
        <p class="mt-5 max-w-xl leading-relaxed text-stone-300">
          A listening section for released recordings, SoundCloud sketches, and studio samples.
        </p>
      </div>

      <div class="grid gap-5">
        <div class="border border-white/15 bg-stone-950 p-6">
          <p class="text-xs uppercase tracking-[0.28em] text-amber-300">SoundCloud samples</p>
          <h3 class="mt-4 font-serif text-3xl text-white">Featured audio</h3>
          <p class="mt-4 leading-relaxed text-stone-300">
            SoundCloud samples can appear here as featured tracks or an embedded playlist.
          </p>
          {
            artist.soundCloudEmbedUrl ? (
              <>
                <iframe
                  title={`${artist.name} SoundCloud sample`}
                  class="mt-6 h-[300px] w-full border-0"
                  scrolling="no"
                  allow="autoplay; encrypted-media"
                  src={artist.soundCloudEmbedUrl}
                ></iframe>
                <p class="mt-3 truncate text-xs text-stone-500">
                  <a
                    href={artist.soundCloudUserUrl}
                    title={artist.soundCloudUserName}
                    target="_blank"
                    rel="noreferrer"
                    class="transition hover:text-amber-200"
                  >
                    {artist.soundCloudUserName}
                  </a>
                  {" · "}
                  <a
                    href={artist.soundCloudUrl}
                    title={artist.soundCloudTrackTitle}
                    target="_blank"
                    rel="noreferrer"
                    class="transition hover:text-amber-200"
                  >
                    {artist.soundCloudTrackTitle}
                  </a>
                </p>
                <a
                  href={artist.soundCloudUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="mt-5 inline-block rounded bg-amber-300 px-5 py-3 text-sm font-semibold text-black transition hover:bg-amber-200"
                >
                  Open SoundCloud
                </a>
              </>
            ) : (
              <p class="mt-6 inline-block rounded border border-white/15 bg-black px-5 py-3 text-sm text-stone-300">
                Samples coming soon
              </p>
            )
          }
        </div>

        <div class="border border-white/15 bg-stone-950 p-6">
          <p class="text-xs uppercase tracking-[0.28em] text-amber-300">Repertoire</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {
              artist.repertoire.map((item) => (
                <span class="rounded border border-white/15 bg-black px-3 py-2 text-sm text-stone-300">
                  {item}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
