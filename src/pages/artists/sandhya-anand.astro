---
import Layout from "../../layouts/Layout.astro";

const artist = {
  name: "Sandhya Anand",
  style: "Carnatic vocals and violin",
  image: "/artist-placeholders/sandhya-anand.jpeg",
  alt: "Portrait of Carnatic musician Sandhya Anand",
  location: "Theorshan featured artist for kutcheris, recordings, and devotional programs",
  websiteUrl: "https://www.sandhyaanand.com/about",
  spotifyUrl: "https://open.spotify.com/artist/4KSrMum9A1NsMHmYzxtVk9?si=PgjMHY9ERiSLN4YmDjzTDg",
  spotifyEmbedUrl: "https://open.spotify.com/embed/artist/4KSrMum9A1NsMHmYzxtVk9?utm_source=generator",
  bookingUrl: "/contact",
  bio:
    "Sandhya Anand is a Carnatic vocalist and violinist whose music brings scholarship, bhava, and stage experience into close listening spaces. A graded artist of All India Radio and Doordarshan, she is also a 2025 Individual Artist Fellow of the New Jersey State Council on the Arts. With deep training in Carnatic music and Sanskrit, Sandhya is a natural fit for Theorshan's intimate kutcheris, devotional programs, and studio recordings.",
  highlights: [
    "Carnatic vocalist and violinist",
    "Graded artist of All India Radio and Doordarshan",
    "2025 NJ State Council on the Arts Individual Artist Fellow",
  ],
  repertoire: ["Kutcheris", "Kritis", "Bhajans", "Violin", "Devotional recordings"],
};
---

<Layout title={`${artist.name} | Theorshan`}>
  <section class="bg-black px-5 py-20 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="overflow-hidden border border-white/15 bg-stone-950">
        <img src={artist.image} alt={artist.alt} class="h-[520px] w-full object-cover object-top" />
      </div>

      <div>
        <p class="text-sm uppercase tracking-[0.35em] text-amber-300">{artist.style}</p>
        <h1 class="mt-5 font-serif text-6xl leading-none text-white sm:text-7xl">{artist.name}</h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-stone-300">{artist.location}</p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a
            href={artist.bookingUrl}
            class="rounded bg-amber-300 px-7 py-4 text-center font-semibold text-black shadow-xl shadow-amber-950/30 transition hover:bg-amber-200"
          >
            Book Sandhya
          </a>

          <a
            href={artist.websiteUrl}
            target="_blank"
            rel="noreferrer"
            class="rounded border border-white/35 bg-white/10 px-7 py-4 text-center font-semibold text-white transition hover:border-amber-300 hover:text-amber-200"
          >
            Artist Website
          </a>

          <a
            href={artist.spotifyUrl}
            target="_blank"
            rel="noreferrer"
            class="rounded border border-white/35 bg-white/10 px-7 py-4 text-center font-semibold text-white transition hover:border-amber-300 hover:text-amber-200"
          >
            Spotify
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-stone-950 px-5 py-20 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="text-sm uppercase tracking-[0.35em] text-amber-300">Bio</p>
        <h2 class="mt-4 font-serif text-4xl text-white">Classical depth for intimate listening.</h2>
      </div>

      <div>
        <p class="text-lg leading-relaxed text-stone-300">{artist.bio}</p>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {
            artist.highlights.map((highlight) => (
              <div class="border border-white/15 bg-black p-5">
                <p class="leading-relaxed text-stone-300">{highlight}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-black px-5 py-20 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="text-sm uppercase tracking-[0.35em] text-amber-300">Listen</p>
        <h2 class="mt-4 font-serif text-4xl text-white">Listen on Spotify.</h2>
        <p class="mt-5 max-w-xl leading-relaxed text-stone-300">
          Explore Sandhya Anand's artist profile and released recordings.
        </p>
      </div>

      <div class="grid gap-5">
        <div class="border border-white/15 bg-stone-950 p-6">
          <p class="text-xs uppercase tracking-[0.28em] text-amber-300">Spotify artist</p>
          <h3 class="mt-4 font-serif text-3xl text-white">{artist.name}</h3>

          <iframe
            data-testid="embed-iframe"
            title={`${artist.name} Spotify artist profile`}
            class="mt-6 h-[352px] w-full rounded-xl border-0"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            src={artist.spotifyEmbedUrl}
          ></iframe>

          <a
            href={artist.spotifyUrl}
            target="_blank"
            rel="noreferrer"
            class="mt-5 inline-block rounded bg-amber-300 px-5 py-3 text-sm font-semibold text-black transition hover:bg-amber-200"
          >
            Open Spotify
          </a>
        </div>

        <div class="border border-white/15 bg-stone-950 p-6">
          <p class="text-xs uppercase tracking-[0.28em] text-amber-300">Programs</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {
              artist.repertoire.map((item) => (
                <span class="rounded border border-white/15 bg-black px-3 py-2 text-sm text-stone-300">
                  {item}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
