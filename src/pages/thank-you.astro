---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Thank You | Theorshan">
  <section class="bg-black px-5 py-24 text-white sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="text-sm uppercase tracking-[0.35em] text-amber-300">Enquiry received</p>
      <h1 class="mt-5 font-serif text-5xl leading-tight text-white sm:text-6xl">
        Thank you for reaching out.
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-stone-300">
        Your message has been sent to Theorshan. We will review your enquiry and get back to you soon.
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a
          href="/"
          class="rounded bg-amber-300 px-7 py-4 text-center font-semibold text-black shadow-xl shadow-amber-950/30 transition hover:bg-amber-200"
        >
          Return Home
        </a>
        <a
          href="/artists"
          class="rounded border border-white/25 bg-white/10 px-7 py-4 text-center font-semibold text-white transition hover:border-amber-300 hover:text-amber-200"
        >
          Explore Artists
        </a>
      </div>
    </div>
  </section>
</Layout>
